{
    // Ignore files referenced by .gitignore (only valid at root)
    "gitignore": true,

    // Custom rules
    "customRules": ["./rules/adobe-heading-increment.js"],

    // Define glob expressions to ignore
    "ignores": [
        "node_modules/",
        "coverage/",
        ".github/",
        "src/pages/config.md"
        ]
}
